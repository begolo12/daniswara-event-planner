NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────
# Local dev: leave DB_DIALECT unset (defaults to sqlite)
# Render production: DATABASE_URL is auto-set; set DB_DIALECT=postgres
DB_DIALECT=sqlite
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=daniswara_event
# DB_USER=your_database_user
# DB_PASS=your_database_password
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=replace_with_strong_random_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret_min_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AI ────────────────────────────────────────────────
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace_with_your_ai_api_key
AI_MODEL=replace_with_your_model_name
AI_ENCRYPTION_KEY=replace_with_32_character_encryption_key

# ── Upload ────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
